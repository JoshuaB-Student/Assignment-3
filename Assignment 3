import random

class ImageRegion:
  def __init__(self, x: int, y: int, width: int, height: int):
    self._x = x
    self._y = y
    self._width = width
    self._height = height
  def get_x(self) -> int:
        return self._x

  def get_y(self) -> int:
        return self._y

  def get_width(self) -> int:
        return self._width

  def get_height(self) -> int:
        return self._height

  def get_bounds(self) -> tuple:
        return (self._x, self._y, self._width, self._height)

  def get_center(self) -> tuple:
        cx = self._x + self._width // 2
        cy = self._y + self._height // 2
        return (cx, cy)
  def contains_point(self, px, py):
    return self._x <= px < self._x + self._width and self._y <= py < self._y + self._height
  def describe(self):
    return f"ImageRegion at ({self._x}, {self._y}), size {self._width}x{self.height}"

class DifferenceRegion(ImageRegion):

  alteration_types = ["colour_shift", "blur", "brightness", "rotation",]

  def __init__(self, x, y, width, height, alteration_type = None):
    super(). __init__(x, y, width, height)
    self.alteration_type = alteration_type or random.choice(self.alteration_types)

    self._found = False

  def mark_as_found(self):
    self._found = True

  def is_found(self):
    return self._found

  def describe(self):
    status = "found" if self._found else "hidden"
    return f"DifferenceRegion at ({self._x}, {self._y})"

class Gamestate:
  max_mistakes = 3

  def __init__(self):
    self.differences = []
    self.mistakes = 0

  def set_differences(self, differences):
    self.differences = differences
    self.mistakes = 0

  def get_remaining(self):
    return sum(1 for d in self.diffrences if not d.is_found())

  def register_click(self, px, py, proximity = 30):
    for diff in self._differences:
      cx, cy = diff.get_center()
      if not diff.is_found() and abs(cx - px) <= proximity and abs(cy - py) <= proximity:
        diff.mark_as_found()
        if self.get_remaining() == 0:
          return {"hit": True, "message": "All differences found!"}
        return {"hit": True, "message": f"{self.get_remaining()} remaining."}

    self.mistakes += 1
    if self.mistakes >= self.max_mistakes:
      return{"hit": False, "message": f"Too many mistakes! {self.get_remaining()} unfound."}
    return {"hit": False, "message": f"Wrong! Mistakes: {self.mistakes}/{self.max_mistakes}"}

  def reveal_all(self):
    return [d for d in self.differnces if not d.is_found()]
